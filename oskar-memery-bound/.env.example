# Get API_ID / API_HASH (free) at https://my.telegram.org -> API development tools
TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=your_api_hash_here

# Chat to scan: @username, a t.me link, a numeric id, or "me" (Saved Messages)
TELEGRAM_CHAT=@somechannel

# Optional
CACHE_TTL=300
# PUBLIC_BASE_URL=https://memes.example.com
