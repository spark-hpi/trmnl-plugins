55)" opacity="0.9"/><ellipse cx="50" cy="30" rx="7" ry="11" fill="black" opacity="0.9"/><ellipse cx="40" cy="35" rx="6" ry="7" fill="black" transform="rotate(-20 40 35)" opacity="0.8"/><ellipse cx="60" cy="35" rx="6" ry="7" fill="black" transform="rotate(20 60 35)" opacity="0.8"/></svg>{% endif %}</div>
        <span class="label label--medium">{{ plant2.name }}</span>
        <span class="label label--base label--gray">{{ plant2.days }}d</span>
      </div>
      
      {% assign plant3 = plants[2] %}
      <div style="text-align: center;">
        <div>{% if plant3.type == 'cloud' %}{{ cloud_plant }}{% elsif plant3.type == 'hanging' %}{{ hanging_plant }}{% elsif plant3.type == 'palm' %}<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 160" width="80" height="80"><path d="M 50 70 L 40 130 Q 38 140 44 144 L 56 144 Q 62 140 60 130 L 50 70" stroke="black" stroke-width="2" fill="none"/><path d="M 20 50 Q 10 20 24 10 Q 30 16 32 40" stroke="black" stroke-width="1.5" fill="none"/><path d="M 50 40 Q 40 10 50 4 Q 60 10 60 40" stroke="black" stroke-width="1.5" fill="none"/><path d="M 80 50 Q 90 20 76 10 Q 70 16 68 40" stroke="black" stroke-width="1.5" fill="none"/><path d="M 30 56 Q 16 30 20 16" stroke="black" stroke-width="1.5" fill="none"/><path d="M 70 56 Q 84 30 80 16" stroke="black" stroke-width="1.5" fill="none"/></svg>{% elsif plant3.type == 'rosemary' %}<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 160" width="80" height="80"><path d="M 50 90 L 44 144 Q 42 150 48 152 L 52 152 Q 58 150 56 144 L 50 90" stroke="black" stroke-width="1.5" fill="none"/><circle cx="44" cy="80" r="4" fill="black"/><circle cx="56" cy="80" r="4" fill="black"/><circle cx="40" cy="70" r="4" fill="black"/><circle cx="60" cy="70" r="4" fill="black"/><circle cx="38" cy="56" r="4" fill="black"/><circle cx="62" cy="56" r="4" fill="black"/><circle cx="40" cy="40" r="4" fill="black"/><circle cx="60" cy="40" r="4" fill="black"/><circle cx="44" cy="24" r="4" fill="black"/><circle cx="56" cy="24" r="4" fill="black"/><circle cx="50" cy="12" r="5" fill="black"/></svg>{% else %}<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" width="65" height="65"><path d="M 50 60 L 45 85 Q 44 90 47 92 L 53 92 Q 56 90 55 85 L 50 60" stroke="black" stroke-width="1.5" fill="none"/><rect x="42" y="80" width="16" height="8" stroke="black" stroke-width="1.5" fill="none"/><ellipse cx="35" cy="55" rx="8" ry="6" fill="black" transform="rotate(-30 35 55)" opacity="0.9"/><ellipse cx="65" cy="55" rx="8" ry="6" fill="black" transform="rotate(30 65 55)" opacity="0.9"/><ellipse cx="50" cy="30" rx="6" ry="10" fill="black" opacity="0.9"/><ellipse cx="40" cy="35" rx="5" ry="6" fill="black" transform="rotate(-20 40 35)" opacity="0.8"/><ellipse cx="60" cy="35" rx="5" ry="6" fill="black" transform="rotate(20 60 35)" opacity="0.8"/></svg>{% endif %}</div>
        <span class="label label--medium">{{ plant3.name }}</span>
        <span class="label label--base label--gray">{{ plant3.days }}d</span>
      </div>
      
      {% assign plant7 = plants[6] %}
      <div style="text-align: center;">
        <div>{% if plant7.type == 'cloud' %}{{ cloud_plant }}{% elsif plant7.type == 'hanging' %}{{ hanging_plant }}{% elsif plant7.type == 'palm' %}<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 160" width="90" height="90"><path d="M 50 70 L 40 130 Q 38 140 44 144 L 56 144 Q 62 140 60 130 L 50 70" stroke="black" stroke-width="2.2" fill="none"/><path d="M 20 50 Q 10 20 24 10 Q 30 16 32 40" stroke="black" stroke-width="1.8" fill="none"/><path d="M 50 40 Q 40 10 50 4 Q 60 10 60 40" stroke="black" stroke-width="1.8" fill="none"/><path d="M 80 50 Q 90 20 76 10 Q 70 16 68 40" stroke="black" stroke-width="1.8" fill="none"/><path d="M 30 56 Q 16 30 20 16" stroke="black" stroke-width="1.8" fill="none"/><path d="M 70 56 Q 84 30 80 16" stroke="black" stroke-width="1.8" fill="none"/></svg>{% elsif plant7.type == 'rosemary' %}<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 160" width="90" height="90"><path d="M 50 90 L 44 144 Q 42 150 48 152 L 52 152 Q 58 150 56 144 L 50 90" stroke="black" stroke-width="1.8" fill="none"/><circle cx="44" cy="80" r="4.5" fill="black"/><circle cx="56" cy="80" r="4.5" fill="black"/><circle cx="40" cy="70" r="4.5" fill="black"/><circle cx="60" cy="70" r="4.5" fill="black"/><circle cx="38" cy="56" r="4.5" fill="black"/><circle cx="62" cy="56" r="4.5" fill="black"/><circle cx="40" cy="40" r="4.5" fill="black"/><circle cx="60" cy="40" r="4.5" fill="black"/><circle cx="44" cy="24" r="4.5" fill="black"/><circle cx="56" cy="24" r="4.5" fill="black"/><circle cx="50" cy="12" r="5.5" fill="black"/></svg>{% else %}<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" width="75" height="75"><path d="M 50 60 L 45 85 Q 44 90 47 92 L 53 92 Q 56 90 55 85 L 50 60" stroke="black" stroke-width="1.6" fill="none"/><rect x="42" y="80" width="16" height="8" stroke="black" stroke-width="1.6" fill="none"/><ellipse cx="35" cy="55" rx="9" ry="7" fill="black" transform="rotate(-30 35 55)" opacity="0.9"/><ellipse cx="65" cy="55" rx="9" ry="7" fill="black" transform="rotate(30 65 55)" opacity="0.9"/><ellipse cx="50" cy="30" rx="7" ry="11" fill="black" opacity="0.9"/><ellipse cx="40" cy="35" rx="6" ry="7" fill="black" transform="rotate(-20 40 35)" opacity="0.8"/><ellipse cx="60" cy="35" rx="6" ry="7" fill="black" transform="rotate(20 60 35)" opacity="0.8"/></svg>{% endif %}</div>
        <span class="label label--medium">{{ plant7.name }}</span>
        <span class="label label--base label--gray">{{ plant7.days }}d</span>
      </div>
    </div>
    
    <!-- Bottom plants (larger focal points) -->
    <div style="display: flex; justify-content: center; gap: 30px; align-items: center; margin-top: 10px;">
      {% assign plant4 = plants[3] %}
      <div style="text-align: center;">
        <div>{% if plant4.type == 'cloud' %}{{ cloud_plant }}{% elsif plant4.type == 'hanging' %}{{ hanging_plant }}{% elsif plant4.type == 'palm' %}<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 160" width="110" height="110"><path d="M 50 70 L 40 130 Q 38 140 44 144 L 56 144 Q 62 140 60 130 L 50 70" stroke="black" stroke-width="2.7" fill="none"/><path d="M 20 50 Q 10 20 24 10 Q 30 16 32 40" stroke="black" stroke-width="2.2" fill="none"/><path d="M 50 40 Q 40 10 50 4 Q 60 10 60 40" stroke="black" stroke-width="2.2" fill="none"/><path d="M 80 50 Q 90 20 76 10 Q 70 16 68 40" stroke="black" stroke-width="2.2" fill="none"/><path d="M 30 56 Q 16 30 20 16" stroke="black" stroke-width="2.2" fill="none"/><path d="M 70 56 Q 84 30 80 16" stroke="black" stroke-width="2.2" fill="none"/></svg>{% elsif plant4.type == 'rosemary' %}<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 160" width="110" height="110"><path d="M 50 90 L 44 144 Q 42 150 48 152 L 52 152 Q 58 150 56 144 L 50 90" stroke="black" stroke-width="2.2" fill="none"/><circle cx="44" cy="80" r="5.5" fill="black"/><circle cx="56" cy="80" r="5.5" fill="black"/><circle cx="40" cy="70" r="5.5" fill="black"/><circle cx="60" cy="70" r="5.5" fill="black"/><circle cx="38" cy="56" r="5.5" fill="black"/><circle cx="62" cy="56" r="5.5" fill="black"/><circle cx="40" cy="40" r="5.5" fill="black"/><circle cx="60" cy="40" r="5.5" fill="black"/><circle cx="44" cy="24" r="5.5" fill="black"/><circle cx="56" cy="24" r="5.5" fill="black"/><circle cx="50" cy="12" r="6.5" fill="black"/></svg>{% else %}<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" width="95" height="95"><path d="M 50 60 L 45 85 Q 44 90 47 92 L 53 92 Q 56 90 55 85 L 50 60" stroke="black" stroke-width="2" fill="none"/><rect x="42" y="80" width="16" height="8" stroke="black" stroke-width="2" fill="none"/><ellipse cx="35" cy="55" rx="10" ry="8" fill="black" transform="rotate(-30 35 55)" opacity="0.9"/><ellipse cx="65" cy="55" rx="10" ry="8" fill="black" transform="rotate(30 65 55)" opacity="0.9"/><ellipse cx="50" cy="30" rx="8" ry="12" fill="black" opacity="0.9"/><ellipse cx="40" cy="35" rx="7" ry="8" fill="black" transform="rotate(-20 40 35)" opacity="0.8"/><ellipse cx="60" cy="35" rx="7" ry="8" fill="black" transform="rotate(20 60 35)" opacity="0.8"/></svg>{% endif %}</div>
        <span class="title title--large">{{ plant4.name }}</span>
        <span class="label label--medium label--gray">{{ plant4.days }}d</span>
      </div>
      
      {% assign plant5 = plants[4] %}
      <div style="text-align: center;">
        <div>{% if plant5.type == 'cloud' %}{{ cloud_plant }}{% elsif plant5.type == 'hanging' %}{{ hanging_plant }}{% elsif plant5.type == 'palm' %}<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 160" width="120" height="120"><path d="M 50 70 L 40 130 Q 38 140 44 144 L 56 144 Q 62 140 60 130 L 50 70" stroke="black" stroke-width="3" fill="none"/><path d="M 20 50 Q 10 20 24 10 Q 30 16 32 40" stroke="black" stroke-width="2.5" fill="none"/><path d="M 50 40 Q 40 10 50 4 Q 60 10 60 40" stroke="black" stroke-width="2.5" fill="none"/><path d="M 80 50 Q 90 20 76 10 Q 70 16 68 40" stroke="black" stroke-width="2.5" fill="none"/><path d="M 30 56 Q 16 30 20 16" stroke="black" stroke-width="2.5" fill="none"/><path d="M 70 56 Q 84 30 80 16" stroke="black" stroke-width="2.5" fill="none"/></svg>{% elsif plant5.type == 'rosemary' %}<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 160" width="120" height="120"><path d="M 50 90 L 44 144 Q 42 150 48 152 L 52 152 Q 58 150 56 144 L 50 90" stroke="black" stroke-width="2.5" fill="none"/><circle cx="44" cy="80" r="6" fill="black"/><circle cx="56" cy="80" r="6" fill="black"/><circle cx="40" cy="70" r="6" fill="black"/><circle cx="60" cy="70" r="6" fill="black"/><circle cx="38" cy="56" r="6" fill="black"/><circle cx="62" cy="56" r="6" fill="black"/><circle cx="40" cy="40" r="6" fill="black"/><circle cx="60" cy="40" r="6" fill="black"/><circle cx="44" cy="24" r="6" fill="black"/><circle cx="56" cy="24" r="6" fill="black"/><circle cx="50" cy="12" r="7" fill="black"/></svg>{% else %}{{ succulent_svg }}{% endif %}</div>
        <span class="title title--large">{{ plant5.name }}</span>
