<div style="position:absolute;inset:0;width:400px;height:240px;overflow:hidden;background:#ffffff;color:#000000;font-family:'Inter',Arial,sans-serif;">
  <svg width="400" height="240" viewBox="0 0 800 430" preserveAspectRatio="xMidYMid slice" style="position:absolute;top:0;left:0;">
    {% for p in paths %}<polyline points="{{ p }}" fill="none" stroke="#000000" stroke-width="1.3" stroke-linejoin="round" stroke-linecap="round"/>{% endfor %}
  </svg>
  <div style="position:absolute;left:0;bottom:0;padding:3px 10px;background:#ffffff;border-top:2px solid #000000;border-right:2px solid #000000;font-weight:800;font-size:17px;">{{ city }}</div>
</div>
