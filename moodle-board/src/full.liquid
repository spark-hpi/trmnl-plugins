{% comment %} Deadlines are live from the Moodle poll. Lecture/exam rows and the
   course map between the markers below are written by ./setup.sh — edit there,
   not by hand. 3 cols: next exam (hero) · all exams · assignments. {% endcomment %}
{% assign nowsec = 'now' | date: '%s' | plus: 0 %}
{% assign wd = 'now' | date: '%u' %}
<!-- I18N -->
{% assign l_next_exam = "Next exam" %}{% assign l_next_assignment = "Next assignment" %}{% assign l_exams = "Exams" %}{% assign l_assignments = "Assignments" %}{% assign l_due = "Due" %}{% assign l_days = "Days" %}{% assign l_day = "Day" %}{% assign l_no_exam = "no exam" %}{% assign l_no_assignment = "no assignment" %}{% assign l_no_assignments = "no assignments" %}{% assign l_token_invalid = "Token invalid" %}{% assign l_token_hint = "restart ./setup.sh" %}
<!-- /I18N -->
<!-- EXAMS -->
      {% assign exams = "1781517600|recht|15.06.,1783936800|BIS|13.07.,1785146400|DBS|27.07.,1785837600|PT II|04.08.,1786442400|Ethik|11.08.,1787047200|MA II|18.08." | split: "," %}
<!-- /EXAMS -->
{% comment %} find the single nearest future exam (hero) and count how many are still
   ahead, so the exam column can size its numbers to always fit — no JS fit-value
   engine (it aborts the overflow engine used by the Abgaben column). {% endcomment %}
{% assign next_name = '' %}{% assign next_date = '' %}{% assign next_days = 0 %}{% assign exam_count = 0 %}
{% for e in exams %}{% assign p = e | split: "|" %}{% if p.size >= 3 %}{% assign u = p[0] | plus: 0 %}{% if u > nowsec %}{% assign exam_count = exam_count | plus: 1 %}{% if next_name == '' %}{% assign next_name = p[1] %}{% assign next_date = p[2] %}{% assign next_days = u | minus: nowsec | divided_by: 86400 %}{% endif %}{% endif %}{% endif %}{% endfor %}
{% comment %} the exam column skips the hero (nearest exam, shown top-left), so size its
   numbers from the count actually rendered there: exam_count minus the hero {% endcomment %}
{% assign exam_shown = exam_count | minus: 1 %}
{% comment %} sizes account for the 2-line label (bold course + Days·date) under each number {% endcomment %}{% if exam_shown <= 1 %}{% assign exam_val = 'value--xxlarge' %}{% elsif exam_shown <= 2 %}{% assign exam_val = 'value--xlarge' %}{% elsif exam_shown <= 3 %}{% assign exam_val = 'value--large' %}{% elsif exam_shown <= 5 %}{% assign exam_val = 'value--base' %}{% else %}{% assign exam_val = 'value--small' %}{% endif %}
{% comment %} flatten every course's future assignments into sorted "duedate|name|label" rows.
   Built here (NOT read from shared.liquid) so the hero and the Abgaben column share one source
   and can't diverge on a real device, where shared.liquid is NOT prepended. The COURSEMAP region
   (course id → short label) is written by ./setup.sh — keep it as the file's only COURSEMAP. {% endcomment %}
{% assign rows = "" %}
{% for c in courses %}{% assign clabel = c.shortname %}{% case c.id %}
      <!-- COURSEMAP -->
      {% when 1127 %}{% assign clabel = "MA II" %}
      {% when 1107 %}{% assign clabel = "PT II" %}
      {% when 1136 %}{% assign clabel = "BIS" %}
      {% when 1081 %}{% assign clabel = "DBS" %}
      {% when 1093 %}{% assign clabel = "Ethik" %}
      {% when 1091 %}{% assign clabel = "Recht" %}
      <!-- /COURSEMAP -->
      {% endcase %}{% for a in c.assignments %}{% if a.duedate > nowsec %}{% capture row %}{{ a.duedate }}|{{ a.name }}|{{ clabel }}{% endcapture %}{% assign rows = rows | append: row | append: "~~" %}{% endif %}{% endfor %}{% endfor %}
{% comment %} 10-digit unix prefix ⇒ lexical sort == numeric == soonest first {% endcomment %}
{% assign rows = rows | split: "~~" | sort %}
{% comment %} nearest upcoming assignment (Übung) for the second hero — the FIRST valid row.
   NOT rows[0]: PHP Liquid (byos_laravel/larapaper) keeps the trailing "" that split leaves,
   which sorts to rows[0] and made the hero read empty → "no assignment" on device while the
   column (which guards every row) worked. Ruby Liquid (trmnlp) drops it, hiding the bug. {% endcomment %}
{% assign next_ueb_name = '' %}{% assign next_ueb_label = '' %}{% assign next_ueb_days = 0 %}{% assign ueb_found = false %}
{% for r in rows %}{% unless ueb_found %}{% assign ap = r | split: "|" %}{% if ap.size >= 3 %}{% assign next_ueb_name = ap[1] %}{% assign next_ueb_label = ap[2] %}{% assign next_ueb_days = ap[0] | plus: 0 | minus: nowsec | divided_by: 86400 %}{% assign ueb_found = true %}{% endif %}{% endunless %}{% endfor %}

<div class="layout">
  {% comment %} self--stretch on .columns too: .layout centers its content-sized child, so
     without it the whole board floats with dead air above the headers and below the last
     row (same failure as the old h--full dead-space bug, one level up) {% endcomment %}
  <div class="columns self--stretch">

    {% comment %} two equal heroes as normal items (meta left bar), split by a divider:
       next exam on top, next assignment below. h--full so they fill the column height. {% endcomment %}
    <div class="column self--stretch">
      <div class="item grow basis--0">
        <div class="meta"></div>
        <div class="content flex flex--col flex--left">
          {% if next_name != '' %}
          {% assign kd = l_days %}{% if next_days == 1 %}{% assign kd = l_day %}{% endif %}
          <span class="label label--large">{{ l_next_exam }}</span>
          {% comment %} ponytail: inline align-items:baseline — no baseline flex utility exists; baseline of the days word == visual bottom of the digits {% endcomment %}
          <div class="flex flex--row gap--small" style="align-items:baseline">
            <span class="value value--xxlarge value--tnums">{{ next_days }}</span>
            <span class="label">{{ kd }}</span>
          </div>
          <div class="flex flex--row gap--xsmall" style="align-items:baseline">
            <span class="label font--bold">{{ next_name }}</span>
            <span class="label label--small">· {{ next_date }}</span>
          </div>
          {% else %}
          <span class="value value--xxxlarge">–</span>
          <span class="label">{{ l_no_exam }}</span>
          {% endif %}
        </div>
      </div>
      <div class="divider"></div>
      <div class="item grow basis--0">
        <div class="meta"></div>
        <div class="content flex flex--col flex--left">
          {% if next_ueb_name != '' %}
          {% assign ud = l_days %}{% if next_ueb_days == 1 %}{% assign ud = l_day %}{% endif %}
          <span class="label label--large">{{ l_next_assignment }}</span>
          <div class="flex flex--row gap--small" style="align-items:baseline">
            <span class="value value--xxlarge value--tnums">{{ next_ueb_days }}</span>
            <span class="label">{{ ud }}</span>
          </div>
          <div class="flex flex--row gap--xsmall" style="align-items:baseline">
            <span class="label font--bold">{{ next_ueb_label }}</span>
            <span class="label label--small">· {{ next_ueb_name | truncate: 24 }}</span>
          </div>
          {% else %}
          <span class="value value--xxxlarge">–</span>
          <span class="label">{{ l_no_assignment }}</span>
          {% endif %}
        </div>
      </div>
    </div>

    <div class="column self--stretch">
      <span class="label label--underline pb--2">{{ l_exams }}</span>
      {% comment %} self--stretch fills the column height; item grow distributes the exams evenly
         over it (no dead space above the title bar); flex--center vertically centers each item's
         content; exam_val (from the count) shrinks the number so they never overflow {% endcomment %}
      {% comment %} the string is unix-sorted, so the FIRST future exam is the hero — skip it
         here instead of repeating it {% endcomment %}
      {% assign hero_exam_skipped = false %}
      {% for e in exams %}{% assign p = e | split: "|" %}{% if p.size >= 3 %}{% assign u = p[0] | plus: 0 %}{% if u > nowsec %}{% if hero_exam_skipped == false %}{% assign hero_exam_skipped = true %}{% else %}{% assign days = u | minus: nowsec | divided_by: 86400 %}{% assign ed = l_days %}{% if days == 1 %}{% assign ed = l_day %}{% endif %}
        <div class="item grow">
          <div class="meta"></div>
          {% comment %} gap--none: .content's default child gap read as dead air between the
             number and its caption; the number's own line-height is breathing room enough {% endcomment %}
          <div class="content flex flex--col flex--left gap--none">
            <div class="flex flex--row gap--small" style="align-items:baseline">
              <span class="value {{ exam_val }} value--tnums">{{ days }}</span>
              <span class="label label--small">{{ ed }}</span>
            </div>
            {% comment %} course leads (size + weight; size survives the Classic bundle where
               font--bold is a no-op), date follows quiet {% endcomment %}
            <div class="flex flex--row gap--xsmall" style="align-items:baseline">
              <span class="label font--bold">{{ p[1] }}</span>
              <span class="label label--small">· {{ p[2] }}</span>
            </div>
          </div>
        </div>
      {% endif %}{% endif %}{% endif %}{% endfor %}
      {% comment %} only claim "no exam" when there is truly none anywhere — with exactly one
         (living in the hero) the column stays blank rather than lying {% endcomment %}
      {% if exam_count == 0 %}<span class="description">{{ l_no_exam }}</span>{% endif %}
    </div>

    <div class="column self--stretch">
      <span class="label label--underline pb--2">{{ l_assignments }}</span>
      {% comment %} rows (sorted upcoming assignments) is built once at the top of this file.
         Cap + "and N more" are computed HERE in Liquid, not by the JS overflow engine — the
         engine doesn't reliably run on-device (rows then wrap 2 lines and clip past the title
         bar). Same reason exam numbers are Liquid-sized. amax picked so rows never overflow. {% endcomment %}
      {% assign total = 0 %}{% for r in rows %}{% assign cp = r | split: "|" %}{% if cp.size >= 3 %}{% assign total = total | plus: 1 %}{% endif %}{% endfor %}
      {% comment %} the nearest assignment lives in the hero, not in this column — exclude it
         from the list AND from the "and N more" math {% endcomment %}
      {% if total > 0 %}{% assign total = total | minus: 1 %}{% endif %}
      {% comment %} self--stretch + item grow fill the column height so few assignments spread
         over it instead of bunching at the top with dead space above the title bar {% endcomment %}
      {% assign amax = 4 %}{% assign shown = 0 %}
      {% comment %} rows is sorted, so the FIRST valid row is the hero — skip it {% endcomment %}
      {% assign hero_row_skipped = false %}
      {% for r in rows %}{% assign p = r | split: "|" %}{% if p.size >= 3 %}{% if hero_row_skipped == false %}{% assign hero_row_skipped = true %}{% else %}{% if shown < amax %}{% assign adays = p[0] | plus: 0 | minus: nowsec | divided_by: 86400 %}{% assign ad = l_days %}{% if adays == 1 %}{% assign ad = l_day %}{% endif %}
        <div class="item grow">
          <div class="meta"></div>
          {% comment %} hierarchy: course leads (base size + bold), days number is the anchor,
             title trails smallest. gap--none keeps the 3 lines reading as ONE unit — the
             default .content gap made rows so tall that amax=4 overflowed the column {% endcomment %}
          <div class="content flex flex--col flex--left gap--none">
            <span class="label font--bold">{{ p[2] }}</span>
            <div class="flex flex--row gap--small" style="align-items:baseline">
              <span class="value value--base value--tnums">{{ adays }}</span>
              <span class="label label--small">{{ ad }}</span>
            </div>
            <span class="label label--small" data-clamp="1">{{ p[1] | truncate: 32 }}</span>
          </div>
        </div>
      {% assign shown = shown | plus: 1 %}{% endif %}{% endif %}{% endif %}{% endfor %}
      {% assign more = total | minus: amax %}
      {% comment %} "no assignments" only when there is truly none anywhere — with exactly one
         (living in the hero) the column stays blank rather than lying {% endcomment %}
      {% if errorcode or exception %}<span class="value value--large">⚠</span><span class="label">{{ l_token_invalid }}</span><span class="label label--small">{{ l_token_hint }}</span>{% elsif ueb_found == false %}<span class="description">{{ l_no_assignments }}</span>{% elsif more > 0 %}
      {% comment %} counter styled like the framework's native overflow counter: an item
         row with meta bar + base-size gray label, not a footnote {% endcomment %}
      <div class="item">
        <div class="meta"></div>
        <div class="content"><span class="label label--gray font--bold">and {{ more }} more</span></div>
      </div>
      {% endif %}
    </div>

  </div>
</div>
<div class="title_bar"><span class="title">Moodle</span><span class="instance">{% if errorcode or exception %}⚠ {{ l_token_invalid }}{% else %}{{ 'now' | date: '%d.%m %H:%M' }}{% endif %}</span></div>
